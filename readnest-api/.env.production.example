# KoDeploy production environment checklist.
# If KoDeploy MySQL dependency reserves DATABASE_URL, do not add DATABASE_URL manually.

NODE_ENV="production"
PORT=3000

JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# KoDeploy target: use DB_* values. DATABASE_URL remains optional for other hosts.
# DATABASE_URL="mysql://user:password@host:3306/database"
DB_HOST=""
DB_PORT=3306
DB_NAME=""
DB_USER=""
DB_PASSWORD=""

# Upstash/managed Redis: prefer REDIS_URL.
REDIS_URL="rediss://default:password@host.upstash.io:6379"
REDIS_HOST=""
REDIS_PORT=6379
REDIS_USERNAME=""
REDIS_PASSWORD=""
REDIS_TLS=false

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

DAILY_SAVE_LIMIT=50
SUMMARY_RETRY_LIMIT=3
PLAYWRIGHT_CHANNEL="chrome"
PLAYWRIGHT_PAGE_TIMEOUT_MS=45000
PLAYWRIGHT_SCROLL_COUNT=3
EXTRACT_TEXT_LIMIT=50000
